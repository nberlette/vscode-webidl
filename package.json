{
  "name": "webidl",
  "version": "0.1.0",
  "publisher": "nberlette",
  "license": "MIT",
  "type": "module",
  "main": "./dist/extension.cjs",
  "module": "./dist/extension.js",
  "browser": "./dist/web/extension.js",
  "types": "./dist/extension.d.ts",
  "displayName": "WebIDL Language Support",
  "description": "WebIDL language support for VSCode, including syntax highlighting, validation, and formatting for *.webidl and *.idl files.",
  "author": {
    "name": "Nicholas Berlette",
    "email": "nick@berlette.com",
    "url": "https://github.com/nberlette"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nberlette/vscode-webidl.git"
  },
  "icon": "./assets/logo-webidl.png",
  "devEngines": {
    "runtime": {
      "name": "deno",
      "version": "^2.8.0",
      "onFail": "download"
    },
    "packageManager": {
      "name": "deno",
      "version": "^2.8.0",
      "onFail": "download"
    }
  },
  "badges": [
    {
      "url": "https://vsmarketplacebadges.dev/version/nberlette.webidl.png?style=for-the-badge",
      "href": "https://github.com/nberlette/vscode-webidl/releases",
      "description": "VSCode Marketplace Version: nberlette.webidl"
    },
    {
      "url": "https://img.shields.io/github/actions/workflow/status/nberlette/vscode-webidl/ci.yml?style=for-the-badge&logo=github-actions",
      "href": "https://github.com/nberlette/vscode-webidl/actions",
      "description": "CI Status"
    },
    {
      "url": "https://img.shields.io/coverallsCoverage/github/nberlette/vscode-webidl?style=for-the-badge&logo=coveralls",
      "href": "https://coveralls.io/github/nberlette/vscode-webidl?branch=main",
      "description": "Test Coverage"
    },
    {
      "url": "https://img.shields.io/github/languages/top/nberlette/vscode-webidl?style=for-the-badge",
      "href": "https://github.com/nberlette/vscode-webidl",
      "description": "Top Language"
    }
  ],
  "categories": [
    "Programming Languages",
    "Linters",
    "Formatters"
  ],
  "contributes": {
    "languages": [
      {
        "id": "webidl",
        "aliases": ["WebIDL", "webidl"],
        "extensions": [".webidl", ".idl"],
        "firstLine": "^((//|/[*][*]?) *)?(-[*]- *)?(Mode: *)?(Web)?IDL( *-[*]-)?",
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "webidl",
        "scopeName": "source.webidl",
        "path": "./syntaxes/webidl.tmLanguage.json"
      }
    ],
    "commands": [
      {
        "command": "webidl.validate",
        "title": "WebIDL: Validate Document"
      },
      {
        "command": "webidl.format",
        "title": "WebIDL: Format Document"
      }
    ]
  },
  "scripts": {
    "clean": "deno run -A npm:rimraf dist dist-test .artifacts",
    "typecheck": "deno run -A tsgo --noEmit -p tsconfig.json",
    "compile": "deno run -A tsgo -p tsconfig.json",
    "compile:desktop": "deno run -A webpack-cli --config webpack.node.config.js",
    "compile:web": "deno run -A webpack-cli --config webpack.config.js",
    "prebuild": "deno task clean",
    "build": "deno task compile && deno task compile:desktop && deno task compile:web",
    "prepackage": "deno task build",
    "package": "deno run -A scripts/package.ts",
    "test": "deno test --allow-all --parallel --no-check=remote",
    "test:coverage": "deno test --allow-all --coverage --clean --parallel --no-check=remote",
    "watch": "deno run -A tsgo -w -p tsconfig.json",
    "watch:web": "deno run -A webpack-cli --config webpack.config.js --watch",
    "ci": "deno task typecheck && deno task build && deno task test"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "@types/vscode": "^1.90.0",
    "@types/webidl2": "24.4.4",
    "ts-loader": "^9.4.3",
    "typescript": "^6.0.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^7.0.2"
  },
  "dependencies": {
    "webidl2": "^24.5.0"
  }
}
